# =============================================================================
# simple-ai-worker — Environment Variable Template
# =============================================================================
#
# Copy this file to .env and fill in the real values:
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All values are loaded exclusively by pydantic-settings BaseSettings —
# no load_dotenv() call exists in application code.
#
# Sections:
#   1. CrewAI Enterprise Platform
#   2. LLM / AI Providers
#   3. Slack Bolt (Events API HTTP server)
#   4. Scheduler
#   5. Agent Config
# =============================================================================


# -----------------------------------------------------------------------------
# 1. CrewAI Enterprise Platform
# -----------------------------------------------------------------------------
#
# Required from Phase 5 onward.
#
# How to obtain:
#   1. Log in to https://app.crewai.com
#   2. Go to Integrations page → connect JIRA / ClickUp / GitHub / Slack
#      (complete OAuth for each service)
#   3. Copy the Enterprise Integration Token shown after connecting
#
# Used by: every Agent(apps=[...]) native tool integration.
# JIRA / ClickUp / GitHub OAuth credentials are managed entirely by CrewAI AMP
# and are NOT stored here.
#
CREWAI_PLATFORM_INTEGRATION_TOKEN=


# -----------------------------------------------------------------------------
# 2. LLM / AI Providers
# -----------------------------------------------------------------------------
#
# At least one of OPENAI_API_KEY or ANTHROPIC_API_KEY must be set,
# depending on the value of DEFAULT_LLM_PROVIDER.
#
# --- OpenAI ---
# Required when DEFAULT_LLM_PROVIDER=openai (the default).
# How to obtain: https://platform.openai.com/account/api-keys
#
OPENAI_API_KEY=

# --- Anthropic ---
# Required only when DEFAULT_LLM_PROVIDER=anthropic.
# How to obtain: https://console.anthropic.com/account/keys
#
ANTHROPIC_API_KEY=

# --- Default LLM Provider ---
# Controls which provider is used as the default for all agents.
# Allowed values: openai | anthropic
# Default: openai
#
DEFAULT_LLM_PROVIDER=openai


# -----------------------------------------------------------------------------
# 3. Slack Bolt — Events API HTTP server (direct bot credentials)
# -----------------------------------------------------------------------------
#
# Required from Phase 6 onward (simple-ai-slack process only).
# These credentials are used DIRECTLY by the Slack Bolt Events API HTTP server
# and are SEPARATE from any Slack credentials managed by CrewAI AMP.
#
# Setup steps:
#   1. Go to https://api.slack.com/apps → Create New App → From Scratch
#      Name the app "ai-worker"
#   2. OAuth & Permissions → Add bot scopes:
#        channels:read, channels:history, chat:write,
#        app_mentions:read, im:read, im:history, im:write
#      → Install App to workspace → copy Bot User OAuth Token (xoxb-…)
#   3. Basic Information → copy Signing Secret
#   4. Event Subscriptions → Enable → set Request URL to:
#        https://<public-host>/slack/events
#      (use `ngrok http 3000` or `cloudflared tunnel` in local dev)
#      → Subscribe to bot events: app_mention, message.im
#   5. Socket Mode must remain DISABLED
#
# Human usage convention (once running):
#   @ai-worker [planner] <message>   → routed to Planner Agent
#   @ai-worker [dev lead] <message>  → routed to Dev Lead Agent
#   DM to @ai-worker with same tag prefix also works.
#

# Bot User OAuth Token (xoxb-…)
# Authenticates the Bolt app when posting messages back to Slack.
SLACK_BOT_TOKEN=

# Signing Secret
# Used by Bolt to verify the HMAC signature of every incoming event payload.
SLACK_SIGNING_SECRET=

# TCP port for the built-in Bolt HTTP server (POST /slack/events).
# AsyncApp.start() always binds to 0.0.0.0 — only the port is configurable.
# Default: 3000
SLACK_PORT=3000


# -----------------------------------------------------------------------------
# 4. Scheduler
# -----------------------------------------------------------------------------
#
# Controls APScheduler behaviour at runtime.
#

# Default polling interval for all interval-based jobs.
# Unit: seconds. Default: 60
SCHEDULER_INTERVAL_SECONDS=60

# Timezone for the BackgroundScheduler.
# Any timezone string recognised by pytz is valid.
# Examples: UTC, Asia/Taipei, America/New_York
# Default: UTC
SCHEDULER_TIMEZONE=UTC

# Maximum number of dev-agent Crews that may run concurrently.
# Controls the size of the bounded ThreadPoolExecutor.
# Default: 3
MAX_CONCURRENT_DEV_AGENTS=3


# -----------------------------------------------------------------------------
# 5. Agent Config
# -----------------------------------------------------------------------------
#
# Path to the YAML agent configuration file.
# Relative paths are resolved from the working directory (project root).
# Default: config/agents.yaml
#
AGENT_CONFIG_PATH=config/agents.yaml


# -----------------------------------------------------------------------------
# 6. MCP Server Authentication Tokens
# -----------------------------------------------------------------------------
#
# Bearer tokens injected into the Authorization header when the agent
# connects to each self-hosted MCP server.
# Required only when the corresponding MCP server is referenced in
# agents.yaml (mcp_servers.<name>).
#
# How to obtain:
#   Generate a secure random token for each self-hosted MCP server and
#   configure the server to accept that token.
#   Example (openssl): openssl rand -hex 32
#

# Bearer token for the JIRA MCP server.
# Required when mcp_servers.jira is configured in agents.yaml.
MCP_JIRA_TOKEN=

# Bearer token for the ClickUp MCP server.
# Required when mcp_servers.clickup is configured in agents.yaml.
MCP_CLICKUP_TOKEN=

# Bearer token for the GitHub MCP server.
# Required when mcp_servers.github is configured in agents.yaml.
MCP_GITHUB_TOKEN=

# Bearer token for the Slack MCP server.
# Required when mcp_servers.slack is configured in agents.yaml.
MCP_SLACK_TOKEN=


# -----------------------------------------------------------------------------
# 7. MCP Server Base URLs
# -----------------------------------------------------------------------------
#
# Base URLs for each self-hosted MCP server endpoint.
# Defaults point to localhost ports for local development.
# Override these in production with the actual internal/public URLs.
#
# Port convention (local dev): 8100=jira, 8101=clickup, 8102=github, 8103=slack
#

MCP_JIRA_URL=http://127.0.0.1:8100/mcp
MCP_CLICKUP_URL=http://127.0.0.1:8101/mcp
MCP_GITHUB_URL=http://127.0.0.1:8102/mcp
MCP_SLACK_URL=http://127.0.0.1:8103/mcp


# -----------------------------------------------------------------------------
# 8. Atlassian / JIRA — required by the mcp-jira Docker Compose service
# -----------------------------------------------------------------------------
#
# The sooperset/mcp-atlassian server authenticates with Jira URL, email and
# API token.  docker-compose.yml maps ATLASSIAN_URL → JIRA_URL and
# ATLASSIAN_EMAIL → JIRA_USERNAME inside the container.
#
# ATLASSIAN_URL   — your Atlassian Cloud site root URL.
#                   Example: https://your-org.atlassian.net
#
# ATLASSIAN_EMAIL — the email address of the Atlassian account that owns
#                   the API token below.
#
# MCP_JIRA_TOKEN  — Atlassian API token (reused from section 6).
#                   Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
#
ATLASSIAN_URL=https://your-org.atlassian.net
ATLASSIAN_EMAIL=you@example.com
# MCP_JIRA_TOKEN is already defined in section 6 above.


# -----------------------------------------------------------------------------
# 9. ClickUp — required by the mcp-clickup Docker Compose service
# -----------------------------------------------------------------------------
#
# CLICKUP_TEAM_ID — optional ClickUp Workspace/Team ID used to scope all
#                   API operations to a specific workspace.
#                   Leave blank to use the default team for the token.
#                   Find it at: https://app.clickup.com/<team_id>/home
#
CLICKUP_TEAM_ID=
