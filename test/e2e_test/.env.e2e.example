# =============================================================================
# test/e2e_test/.env.e2e.example — E2E Test Environment Variable Template
# =============================================================================
#
# Copy this file to test/e2e_test/.env.e2e and fill in real values:
#
#   cp test/e2e_test/.env.e2e.example test/e2e_test/.env.e2e
#
# NEVER commit test/e2e_test/.env.e2e to version control.
#
# This file is loaded ONLY by the E2E test layer (test/e2e_test/).
# The application runtime reads .env at the project root — NOT this file.
#
# =============================================================================
# Sections:
#   1. LLM API Keys        (required for all E2E tests)
#   2. E2E LLM Config      (model + provider selection)
#   3. MCP Server URLs     (blank = stub mode; set = live mode)
#   4. Atlassian / JIRA    (live mode only)
#   5. ClickUp             (live mode only)
#   6. GitHub              (live mode only)
#   7. Slack               (live mode only)
# =============================================================================


# -----------------------------------------------------------------------------
# 1. LLM API Keys
# -----------------------------------------------------------------------------
# At least one must be set. All E2E tests are automatically skipped when absent.
# These use their canonical names (no E2E_ prefix) because CrewAI / LiteLLM
# reads them directly from the environment by these exact names.
#
# How to obtain:
#   OpenAI:    https://platform.openai.com/account/api-keys
#   Anthropic: https://console.anthropic.com/account/keys
#
OPENAI_API_KEY=
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# 2. E2E LLM Config
# -----------------------------------------------------------------------------
# The E2E_ prefix distinguishes these from application-level settings.
#
# Default LLM model (gpt-4o-mini is sufficient and cost-effective for E2E stubs)
E2E_LLM_MODEL=gpt-4o-mini
# LLM provider: openai | anthropic
E2E_LLM_PROVIDER=openai


# -----------------------------------------------------------------------------
# 3. MCP Server URLs  (Two-Tier E2E Toggle)
# -----------------------------------------------------------------------------
# STUB MODE (default):
#   Leave all E2E_MCP_*_URL values empty.
#   Each test spins up a pytest-httpserver stub on a random port.
#   Only OPENAI_API_KEY (section 1) is needed.
#
# LIVE MODE:
#   Set all four values to point at the running docker-compose.e2e.yml services.
#   Start with:  docker compose \
#                  -f test/e2e_test/docker-compose.e2e.yml \
#                  --env-file test/e2e_test/.env.e2e \
#                  up -d --wait
#
# Port convention (live mode): 18100=jira, 18101=clickup, 18102=github, 18103=slack
# DIFFERENT from main docker-compose.yml ports (8100-8103) to avoid conflicts.
#

# JIRA MCP server URL  (stub: leave empty  |  live: http://127.0.0.1:18100/mcp)
E2E_MCP_JIRA_URL=

# ClickUp MCP server URL  (stub: leave empty  |  live: http://127.0.0.1:18101/mcp)
E2E_MCP_CLICKUP_URL=

# GitHub MCP server URL  (stub: leave empty  |  live: http://127.0.0.1:18102/mcp)
E2E_MCP_GITHUB_URL=

# Slack MCP server URL  (stub: leave empty  |  live: http://127.0.0.1:18103/mcp)
E2E_MCP_SLACK_URL=


# -----------------------------------------------------------------------------
# 4. Atlassian / JIRA  (live mode only - required when E2E_MCP_JIRA_URL is set)
# -----------------------------------------------------------------------------
# IMPORTANT: Use a DEDICATED TEST PROJECT (e.g. TEST, SANDBOX).
# E2E tests create, modify, and transition tickets in this project.
# DO NOT point this at a production project.
#
# JIRA Cloud instance URL
E2E_ATLASSIAN_URL=
# Email of the Atlassian account owning the API token
E2E_ATLASSIAN_EMAIL=
# Atlassian API token - generate at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
E2E_MCP_JIRA_TOKEN=
# Optional: JIRA project key to scope queries (e.g. TEST, SANDBOX)
E2E_JIRA_PROJECT_KEY=


# -----------------------------------------------------------------------------
# 5. ClickUp  (live mode only - required when E2E_MCP_CLICKUP_URL is set)
# -----------------------------------------------------------------------------
# IMPORTANT: Use a DEDICATED TEST LIST.
# E2E tests create and modify tasks in this list.
#
# ClickUp personal API token (pk_...)
E2E_MCP_CLICKUP_TOKEN=
# ClickUp list ID - find in URL: https://app.clickup.com/<team_id>/v/li/<list_id>
E2E_CLICKUP_LIST_ID=
# Optional Workspace/Team ID
E2E_CLICKUP_TEAM_ID=


# -----------------------------------------------------------------------------
# 6. GitHub  (live mode only - required when E2E_MCP_GITHUB_URL is set)
# -----------------------------------------------------------------------------
# IMPORTANT: Use a DEDICATED TEST REPOSITORY.
# E2E tests create, review, and merge pull requests in this repository.
#
# GitHub Personal Access Token
#   Classic PAT: needs repo scope
#   Fine-grained: needs Read+Write on pull_requests + contents
E2E_MCP_GITHUB_TOKEN=
# Test repository (format: owner/repo, e.g. myorg/ai-e2e-sandbox)
E2E_GITHUB_TEST_REPO=


# -----------------------------------------------------------------------------
# 7. Slack  (live mode only - required when E2E_MCP_SLACK_URL is set)
# -----------------------------------------------------------------------------
# IMPORTANT: Use a DEDICATED TEST CHANNEL (e.g. #ai-e2e-test).
# E2E tests post real Slack messages to this channel.
#
# Slack bot token (xoxb-... or xoxp-... depending on MCP server requirements)
E2E_MCP_SLACK_TOKEN=
# Slack channel ID (alphanumeric, found in channel URL - not the display name)
E2E_SLACK_TEST_CHANNEL_ID=

